# Doxygen configuration for code-coverage-analysis

PROJECT_NAME           = "code-coverage-analysis"
PROJECT_BRIEF          = "CFG and callgraph static analysis tooling"
OUTPUT_DIRECTORY       = docs/build
CREATE_SUBDIRS         = NO

OPTIMIZE_OUTPUT_FOR_C  = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

INPUT                  = src docs
FILE_PATTERNS          = *.h *.hpp *.cpp *.md
RECURSIVE              = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
